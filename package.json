{
  "name": "mcp-itglue",
  "version": "0.2.0",
  "mcpName": "io.github.selic/mcp-itglue",
  "description": "MCP server for the IT Glue API — documents, flexible assets, semantic vector search, role-based access control, and bring-your-own-key support",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-itglue": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --transport http",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/index.ts --transport http",
    "test": "vitest run",
    "test:watch": "vitest",
    "bundle": "npm run build && node scripts/bundle.mjs"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "itglue",
    "it-glue",
    "msp",
    "documentation",
    "vector-search",
    "rbac"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "author": "Eugene Samotija (selic) <es@defency.net> (https://defency.net)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/selic/mcp-itglue.git"
  },
  "homepage": "https://github.com/selic/mcp-itglue#readme",
  "bugs": {
    "url": "https://github.com/selic/mcp-itglue/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "openai": "^6.45.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
